{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/schluegge/AXIOM/raw/main/benchmarks/schemas/0.1.0/command-record.schema.json",
  "title": "AXIOM-Bench 0.1 command record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_kind",
    "schema_version",
    "command_id",
    "phase",
    "argv",
    "cwd",
    "environment",
    "started_at",
    "finished_at",
    "duration_ms",
    "return_code",
    "timed_out",
    "output_limited",
    "termination",
    "stdout_path",
    "stdout_sha256",
    "stdout_bytes",
    "stderr_path",
    "stderr_sha256",
    "stderr_bytes"
  ],
  "properties": {
    "document_kind": {"const": "axiom.bench.command-record"},
    "schema_version": {"const": "0.1.0"},
    "command_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"},
    "phase": {"enum": ["format", "check", "public_test", "acceptance_test", "security_test"]},
    "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "cwd": {"type": "string", "minLength": 1},
    "environment": {"type": "object", "additionalProperties": {"type": "string"}},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "duration_ms": {"type": "integer", "minimum": 0},
    "return_code": {"type": ["integer", "null"]},
    "timed_out": {"type": "boolean"},
    "output_limited": {"type": "boolean"},
    "termination": {"enum": ["natural", "terminate", "kill", "not_started"]},
    "stdout_path": {"type": "string", "minLength": 1},
    "stdout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "stdout_bytes": {"type": "integer", "minimum": 0},
    "stderr_path": {"type": "string", "minLength": 1},
    "stderr_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "stderr_bytes": {"type": "integer", "minimum": 0}
  }
}
