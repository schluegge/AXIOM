{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/schluegge/AXIOM/raw/main/benchmarks/schemas/0.1.0/task.schema.json",
  "title": "AXIOM-Bench 0.1 task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_kind",
    "schema_version",
    "task_id",
    "task_version",
    "family",
    "classification",
    "title",
    "prompt_path",
    "candidate_edit_allowlist",
    "visible_paths",
    "variants",
    "budgets",
    "acceptance",
    "provenance",
    "equivalence_review",
    "non_goals"
  ],
  "properties": {
    "document_kind": {"const": "axiom.bench.task"},
    "schema_version": {"const": "0.1.0"},
    "task_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"},
    "task_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "family": {
      "enum": [
        "greenfield_function",
        "compiler_error_repair",
        "logical_repair",
        "mutation_reference",
        "formatter_roundtrip",
        "multi_function_change"
      ]
    },
    "classification": {"enum": ["seed_public_after_freeze", "seed_derived_with_provenance", "controlled_holdout"]},
    "title": {"type": "string", "minLength": 1},
    "prompt_path": {"$ref": "#/$defs/path"},
    "candidate_edit_allowlist": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/path"}
    },
    "visible_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/path"}
    },
    "variants": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axiom", "rust", "zig", "go"],
      "properties": {
        "axiom": {"$ref": "#/$defs/variant"},
        "rust": {"$ref": "#/$defs/variant"},
        "zig": {"$ref": "#/$defs/variant"},
        "go": {"$ref": "#/$defs/variant"}
      }
    },
    "budgets": {"$ref": "#/$defs/budgets"},
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_check_ids", "acceptance_check_ids", "security_check_ids", "required_failure_for_seeded_wrong"],
      "properties": {
        "public_check_ids": {"$ref": "#/$defs/nonEmptyStringSet"},
        "acceptance_check_ids": {"$ref": "#/$defs/nonEmptyStringSet"},
        "security_check_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "required_failure_for_seeded_wrong": {
          "enum": ["acceptance_test_failure", "security_failure", "compile_failure"]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authored_at", "first_public_at", "source_origin", "derived_from_known_benchmark", "source_hashes", "transformation_history", "contamination_notes"],
      "properties": {
        "authored_at": {"type": "string", "format": "date-time"},
        "first_public_at": {"type": ["string", "null"], "format": "date-time"},
        "source_origin": {"type": "string", "minLength": 1},
        "derived_from_known_benchmark": {"type": "boolean"},
        "source_hashes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
        "transformation_history": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "contamination_notes": {"type": "string", "minLength": 1}
      }
    },
    "equivalence_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "behavior_contract", "algorithm_equivalent", "feedback_differences", "review_evidence"],
      "properties": {
        "status": {"enum": ["pending", "passed", "failed"]},
        "behavior_contract": {"type": "string", "minLength": 1},
        "algorithm_equivalent": {"type": "boolean"},
        "feedback_differences": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "review_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "non_goals": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "nonEmptyStringSet": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "language_pack_id",
        "candidate_path",
        "starter_path",
        "reference_solution_path",
        "seeded_wrong_paths",
        "formatter_command",
        "check_command",
        "public_test_command",
        "acceptance_test_command",
        "security_test_command",
        "expected_entry_point",
        "declared_dependencies",
        "variant_notes"
      ],
      "properties": {
        "language": {"enum": ["axiom", "rust", "zig", "go"]},
        "language_pack_id": {"type": "string", "minLength": 1},
        "candidate_path": {"$ref": "#/$defs/path"},
        "starter_path": {"$ref": "#/$defs/path"},
        "reference_solution_path": {"$ref": "#/$defs/path"},
        "seeded_wrong_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/path"}},
        "formatter_command": {"$ref": "#/$defs/command"},
        "check_command": {"$ref": "#/$defs/command"},
        "public_test_command": {"$ref": "#/$defs/command"},
        "acceptance_test_command": {"$ref": "#/$defs/command"},
        "security_test_command": {"type": "array", "items": {"type": "string"}},
        "expected_entry_point": {"type": "string", "minLength": 1},
        "declared_dependencies": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "variant_notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_iterations",
        "max_input_tokens_per_iteration",
        "max_output_tokens_per_iteration",
        "max_total_tokens",
        "max_tool_calls",
        "max_compiler_invocations",
        "command_timeout_seconds",
        "task_timeout_seconds",
        "max_output_bytes",
        "max_feedback_bytes",
        "max_candidate_files",
        "max_candidate_bytes",
        "max_changed_lines"
      ],
      "properties": {
        "max_iterations": {"const": 3},
        "max_input_tokens_per_iteration": {"type": "integer", "minimum": 1},
        "max_output_tokens_per_iteration": {"type": "integer", "minimum": 1},
        "max_total_tokens": {"type": "integer", "minimum": 1},
        "max_tool_calls": {"type": "integer", "minimum": 0},
        "max_compiler_invocations": {"type": "integer", "minimum": 1},
        "command_timeout_seconds": {"type": "integer", "minimum": 1},
        "task_timeout_seconds": {"type": "integer", "minimum": 1},
        "max_output_bytes": {"type": "integer", "minimum": 1},
        "max_feedback_bytes": {"type": "integer", "minimum": 1},
        "max_candidate_files": {"type": "integer", "minimum": 1},
        "max_candidate_bytes": {"type": "integer", "minimum": 1},
        "max_changed_lines": {"type": "integer", "minimum": 1}
      }
    }
  }
}
