{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/schluegge/AXIOM/raw/main/benchmarks/schemas/0.1.0/language-pack.schema.json",
  "title": "AXIOM-Bench 0.1 language pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_kind",
    "schema_version",
    "pack_id",
    "pack_version",
    "language",
    "compiler",
    "standard_library",
    "content_path",
    "task_families",
    "concepts",
    "safety_notes",
    "source_paths",
    "source_sha256",
    "measurements",
    "provider_token_counts",
    "leakage_review"
  ],
  "properties": {
    "document_kind": {"const": "axiom.bench.language-pack"},
    "schema_version": {"const": "0.1.0"},
    "pack_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"},
    "pack_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "language": {"enum": ["axiom", "rust", "zig", "go"]},
    "compiler": {"$ref": "#/$defs/component"},
    "standard_library": {"$ref": "#/$defs/component"},
    "content_path": {"$ref": "#/$defs/path"},
    "task_families": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "greenfield_function",
          "compiler_error_repair",
          "logical_repair",
          "mutation_reference",
          "formatter_roundtrip",
          "multi_function_change"
        ]
      }
    },
    "concepts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "safety_notes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "source_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/path"}},
    "source_sha256": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "measurements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["utf8_bytes", "unicode_words", "lines"],
      "properties": {
        "utf8_bytes": {"type": "integer", "minimum": 1},
        "unicode_words": {"type": "integer", "minimum": 1},
        "lines": {"type": "integer", "minimum": 1}
      }
    },
    "provider_token_counts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider", "model", "tokenizer", "tokens", "measured_at"],
        "properties": {
          "provider": {"type": "string", "minLength": 1},
          "model": {"type": "string", "minLength": 1},
          "tokenizer": {"type": "string", "minLength": 1},
          "tokens": {"type": "integer", "minimum": 1},
          "measured_at": {"type": "string", "format": "date-time"}
        }
      }
    },
    "leakage_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "forbidden_identifiers_checked", "task_specific_algorithms_found", "review_evidence"],
      "properties": {
        "status": {"enum": ["pending", "passed", "failed"]},
        "forbidden_identifiers_checked": {"type": "boolean"},
        "task_specific_algorithms_found": {"type": "boolean"},
        "review_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "identity_status"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": ["string", "null"]},
        "identity_status": {"enum": ["pending", "frozen", "unavailable"]}
      }
    }
  }
}
