{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/schluegge/AXIOM/raw/main/benchmarks/schemas/0.1.0/replay-report.schema.json",
  "title": "AXIOM-Bench 0.1 replay report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_kind",
    "schema_version",
    "status",
    "bundle_path",
    "bundle_sha256",
    "task_id",
    "language",
    "adapter",
    "recorded_conformance_passed",
    "recomputed_conformance_passed",
    "subprocesses_executed",
    "files_verified",
    "findings"
  ],
  "properties": {
    "document_kind": {"const": "axiom.bench.replay-report"},
    "schema_version": {"const": "0.1.0"},
    "status": {"enum": ["passed", "failed"]},
    "bundle_path": {"type": "string", "minLength": 1},
    "bundle_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "task_id": {"type": ["string", "null"]},
    "language": {"type": ["string", "null"], "enum": [null, "axiom", "rust", "zig", "go"]},
    "adapter": {"type": ["string", "null"], "enum": [null, "reference", "seeded_wrong"]},
    "recorded_conformance_passed": {"type": ["boolean", "null"]},
    "recomputed_conformance_passed": {"type": ["boolean", "null"]},
    "subprocesses_executed": {"const": 0},
    "files_verified": {"type": "integer", "minimum": 0},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "path", "message"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "message": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
