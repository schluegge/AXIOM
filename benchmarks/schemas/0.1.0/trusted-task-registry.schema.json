{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/schluegge/AXIOM/raw/main/benchmarks/schemas/0.1.0/trusted-task-registry.schema.json",
  "title": "AXIOM-Bench 0.1 trusted task registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "document_kind", "schema_version", "tasks"],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "document_kind": {"const": "axiom.bench.trusted-task-registry"},
    "schema_version": {"const": "0.1.0"},
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "task_path"],
        "properties": {
          "task_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"},
          "task_path": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
