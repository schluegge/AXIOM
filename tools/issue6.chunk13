--- /dev/null
+++ b/examples/invalid_ref_argument_order.ax
@@ -0,0 +1,10 @@
+profile system;
+
+fn update(target: &mut i32, after: i32) -> i32 {
+    return *target + after;
+}
+
+fn main() -> i32 {
+    var value: i32 = 21;
+    return update(&mut value, value);
+}
