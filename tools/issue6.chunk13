--- /dev/null
+++ b/examples/invalid_ref_nested_call_loan.ax
@@ -0,0 +1,17 @@
+profile system;
+
+fn bump(value: &mut i32) -> i32 {
+    *value = *value + 1;
+    return *value;
+}
+
+fn combine(target: &mut i32, after: i32) -> i32 {
+    *target = *target + after;
+    return *target;
+}
