diff --git a/examples/ref_forward.ax b/examples/ref_forward.ax
new file mode 100644
index 0000000000000000000000000000000000000000..b70ed87278ff660812f34d0e61c471e8f5355f97
--- /dev/null
+++ b/examples/ref_forward.ax
@@ -0,0 +1,15 @@
+profile system;
+
+fn increment(value: &mut i32) -> i32 {
+    *value = *value + 1;
+    return *value;
+}
+
+fn forward(value: &mut i32) -> i32 {
+    return increment(value);
+}
+
+fn main() -> i32 {
+    var value: i32 = 41;
+    return forward(&mut value);
+}
