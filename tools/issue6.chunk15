index 0000000000000000000000000000000000000000..48903f5f7107716021e8a7657018b183e69194e5
--- /dev/null
+++ b/examples/ref_mut_call.ax
@@ -0,0 +1,11 @@
+profile system;
+
+fn increment(value: &mut i32) -> i32 {
+    *value = *value + 1;
+    return *value;
+}
+
+fn main() -> i32 {
+    var value: i32 = 41;
+    return increment(&mut value);
+}
diff --git a/examples/ref_nested_call_release.ax b/examples/ref_nested_call_release.ax
new file mode 100644
index 0000000000000000000000000000000000000000..3a01846b6bd24f096a4bf8c701e1b981eb7b401f
--- /dev/null
+++ b/examples/ref_nested_call_release.ax
@@ -0,0 +1,16 @@
+profile system;
+
+fn bump(value: &mut i32) -> i32 {
+    *value = *value + 1;
+    return *value;
+}
+
+fn combine(before: i32, target: &mut i32) -> i32 {
+    *target = *target + before;
+    return *target;
+}
+
+fn main() -> i32 {
+    var value: i32 = 20;
+    return combine(bump(&mut value), &mut value);
+}
