diff --git a/examples/ref_shared_then_mut_scope.ax b/examples/ref_shared_then_mut_scope.ax
new file mode 100644
index 0000000000000000000000000000000000000000..906da6556917b924b92031fc97fe382276ef1390
--- /dev/null
+++ b/examples/ref_shared_then_mut_scope.ax
@@ -0,0 +1,17 @@
+profile system;
+
+fn increment(value: &mut i32) -> i32 {
+    *value = *value + 1;
+    return *value;
+}
+
+fn main() -> i32 {
+    var value: i32 = 41;
+    if true {
+        let shared: &i32 = &value;
+        if *shared != 41 {
+            return 0;
+        }
+    }
+    return increment(&mut value);
+}
