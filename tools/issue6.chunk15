+profile system;
+
+fn read(value: &i32) -> i32 {
+    return *value;
+}
+
+fn main() -> i32 {
+    var values: [i32; 2] = [10, 20];
+    var index: i32 = 2;
+    return read(&values[index]);
+}
diff --git a/examples/ref_scope_release.ax b/examples/ref_scope_release.ax
new file mode 100644
index 0000000000000000000000000000000000000000..039edc30b464a6350d66487720a4690ed97d9123
--- /dev/null
+++ b/examples/ref_scope_release.ax
@@ -0,0 +1,11 @@
+profile system;
+
+fn main() -> i32 {
+    var value: i32 = 40;
+    if true {
+        let reference: &mut i32 = &mut value;
+        *reference = 41;
+    }
+    value = value + 1;
+    return value;
+}
